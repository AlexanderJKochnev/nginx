# BIND_VOLUMES директория для bind томов
BIND_VOLUMES=/mnt/hdd_data/@named_volumes
# этот проект запускать первым - он НЕ создает сети между проектами
# запустить скрипт network.sh
# Сети и IP просто для информации
# сети для prod 172.2x.0.0/24
# для Test сдвиньте подсети: 172.30.x.x, 172.31.x.x
# для local сдвиньте подсети: 172.40.x.x, 172.41.x.x
# SUBNET_REDIS=172.22.0.0/24
# IP_REDIS=172.22.0.10
SUBNET_SEARXNG=172.23.0.0/24
IP_SEARXNG=172.23.0.10
# SUBNET_MONGO=172.24.0.0/24
# IP_MONGO=172.24.0.10
# SUBNET_OLLAMA=172.25.0.0/24
# IP_OLLAMA=172.25.0.10
SUBNET_PREACT=172.26.0.0/24
IP_PREACT=172.26.0.10
SUBNET_CLICK=172.27.0.0/24
IP_CLICK=172.27.0.10
SUBNET_CLICKPG=172.28.0.0/24
IP_CLICKPG=172.28.0.10
# ЭТА ОБЩАЯ ДЛЯ ВСЕХ ОСТАВИТЬ КАК ЕСТЬ
SUBNET_VLLM=172.60.0.0/24
IP_VLLM=172.60.0.10
