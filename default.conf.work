# 6. HTTPS — СУБДОМЕН KAN (kan.abc8888.ru)
server {
    listen 443 ssl;
    http2 on;
    server_name kan.abc8888.ru;

    ssl_certificate /etc/letsencrypt/live/abc8888.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/abc8888.ru/privkey.pem;

    # Сжатие Gzip (как было в рабочем конфиге)
    gzip on;
    gzip_proxied any;
    gzip_types text/plain text/css application/json application/javascript text/xml;
    gzip_vary on;

    location = /robots.txt {
        alias /etc/nginx/static/robots.txt;
    }

    location ~ ^/(.well-known/)?security.txt {
        alias /etc/nginx/static/security.txt;
    }

    location / {
        # Указываем имя контейнера с канбаном и его внутренний порт
        set $upstream_kanban kanboard;
        proxy_pass http://$upstream_kanban:80;

        # Стандартные заголовки для проксирования
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Если канбан использует вебсокеты (часто для real-time обновлений)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

# 6. STUB STATUS статистика сервера
server {
    listen 80;
    server_name localhost;

    location /stub_status {
        stub_status on;
        access_log off;
        # Разрешаем доступ только из внутренней сети Docker
        allow 127.0.0.1;
        allow 172.16.0.0/12; # Типовой диапазон сетей Docker
        deny all;
    }
}

# 7. HTTPS — ОСНОВНОЙ БЛОК (netdata.abc8888.ru)
server {
    listen 443 ssl;
    http2 on;
    server_name netdata.abc8888.ru;

    ssl_certificate /etc/letsencrypt/live/abc8888.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/abc8888.ru/privkey.pem;

    # Сжатие Gzip (как было в рабочем конфиге)
    gzip on;
    gzip_proxied any;
    gzip_types text/plain text/css application/json application/javascript text/xml;
    gzip_vary on;

    location = /robots.txt {
        alias /etc/nginx/static/robots.txt;
    }

    location ~ ^/(.well-known/)?security.txt {
        alias /etc/nginx/static/security.txt;
    }

    # --- FRONTEND (Статика) ---
    location / {
        # Авторизация
        auth_basic "Netdata Private Area";
        auth_basic_user_file /etc/nginx/.htpasswd;

        # set $upstream_front preact_front;
        set $upstream_netdata netdata;
        proxy_pass http://$upstream_netdata:19999;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

        proxy_cache off;
        # proxy_cache_valid 200 60m;
    }
}